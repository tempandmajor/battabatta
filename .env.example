# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (values printed by `npm run db:start`)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:56321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key

# Stripe (platform support payments only — no user-to-user payments)
STRIPE_SECRET_KEY=sk_test_replace
STRIPE_WEBHOOK_SECRET=whsec_replace
STRIPE_SUPPORTER_PRICE_ID=price_replace

# GitHub OAuth (optional; enables "Continue with GitHub")
SUPABASE_AUTH_GITHUB_CLIENT_ID=replace-or-leave-for-local
SUPABASE_AUTH_GITHUB_SECRET=replace-or-leave-for-local
