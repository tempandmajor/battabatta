# Site: set this to the exact production HTTPS origin before submitting the domain to AdSense.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (values printed by `npm run db:start`)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:56321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key

# Stripe (platform support payments only; no user-to-user payments)
STRIPE_SECRET_KEY=sk_test_replace
STRIPE_WEBHOOK_SECRET=whsec_replace
# Recurring USD Price for $10.99/month OMS2 platform support.
STRIPE_SUPPORTER_PRICE_ID=price_replace

# Sentry (error monitoring — DSN is public-safe; auth token is build-time only)
NEXT_PUBLIC_SENTRY_DSN=https://replace@o0.ingest.us.sentry.io/0
SENTRY_DSN=https://replace@o0.ingest.us.sentry.io/0
SENTRY_AUTH_TOKEN=sntrys_replace

# Resend (transactional email)
RESEND_API_KEY=re_replace
RESEND_FROM=Battarbox <no-reply@battarbox.com>

# Google AdSense (disabled until OMS2/legal/privacy review and AdSense approval)
NEXT_PUBLIC_ADS_ENABLED=false
NEXT_PUBLIC_SERVE_EEA_UK_CH=false
NEXT_PUBLIC_ADSENSE_CMP_READY=false
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-replace
NEXT_PUBLIC_ADSENSE_IN_FEED_SLOT_ID=replace
